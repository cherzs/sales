<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_view_form_inherit" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <group id="header_left_group" position="inside">
                <field name="manual_delivery_address" string="Delivery Address" invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
            </group>
        </field>
    </record>

</odoo>
