<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_picking_view_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.view.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']//list//field[@name='product_id']" position="after">
                <field name="customer_description" optional="show" column_invisible="parent.picking_type_code != 'outgoing'"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']//list//field[@name='product_uom']" position="after">
                <field name="customer_uom" optional="show" column_invisible="parent.picking_type_code != 'outgoing'"/>
            </xpath>
        </field>
    </record>

</odoo>
