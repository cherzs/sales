<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_view_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//control" position="inside">
                <button name="action_add_bundle_lines" string="Add a Bundle" type="object" class="px-4 btn-link" context="{'order_id': parent.id}"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//list" position="inside">
                <field name="is_bundle_line" column_invisible="1"/>
                <button invisible="not is_bundle_line" title="Open Bundle Details" name="action_open_sale_order_line" icon="fa-list" type="object" class="px-4 btn-link" context="{'order_id': parent.id}"/>
            </xpath>
        </field>
    </record>


    <record id="sale_order_line_with_bundle_view_form" model="ir.ui.view">
        <field name="name">sale.order.line.with.bundle.view.form</field>
        <field name="model">sale.order.line</field>
        <field name="priority" eval="999"/>
        <field name="arch" type="xml">
            <form string="">
                <group>
                    <field name="product_id" readonly="1"/>
                    <field name="state" invisible="1"/>  
                    <field name="product_uom_readonly" invisible="1"/>
                </group>
                <notebook>
                    <page name="line_ids" string="Bundle Items">
                        <field name="bundle_line_ids">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="qty_delivered" column_invisible="parent.state != 'sale'"/>
                                <field name="uom_id" groups="uom.group_uom" readonly="parent.product_uom_readonly" force_save="1"/>
                                <field name="uom_id" groups="!uom.group_uom" readonly="parent.product_uom_readonly" force_save="1" column_invisible="1"/>
                                <field name="product_uom_category_id" column_invisible="1"/>

                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

</odoo>
