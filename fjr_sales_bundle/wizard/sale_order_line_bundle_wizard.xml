<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_line_bundle_wizard_view_form" model="ir.ui.view">
        <field name="name">sale.order.line.bundle.wizard.view.form</field>
        <field name="model">sale.order.line.bundle.wizard</field>
        <field name="arch" type="xml">
            <form string="">
                <group>
                    <field name="order_id" invisible="1"/>
                    <field name="product_id" options="{'no_create': True}"/>    
                </group>
                <notebook>
                    <page name="line_ids" string="Items">
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="product_id" options="{'no_create': True}"/>
                                <field name="quantity"/>
                                <field name="uom_id" groups="uom.group_uom"/>
                                <field name="uom_id" groups="!uom.group_uom" column_invisible="1"/>

                                <field name="product_uom_category_id" column_invisible="1"/>
                                
                            </list>
                        </field>
                        
                    </page>
                </notebook>
                <footer >
                    <button string="Add Bundle Lines" type="object" name="action_add_bundle_lines" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
