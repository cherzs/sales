<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    
    <record id="purchase_order_inherit_view_form" model="ir.ui.view">
        <field name="name">purchase.order.inherit.view.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <field name="currency_id" position="after">
                <field name="rcs_notes" invisible="not is_rcs_notes" required="is_rcs_notes_mandatory and is_boolean" placeholder="Purchase Order Notes"/>
                <field name="is_rcs_notes" invisible="1" />
                <field name="is_rcs_notes_mandatory" invisible="1" />
                <field name="is_boolean" invisible="1" />
            </field>
        </field>
    </record>
</odoo>
