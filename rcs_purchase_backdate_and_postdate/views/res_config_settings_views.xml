<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="rcs_purchase_backdate_res_config_settings" model="ir.ui.view">
        <field name="name">Backdate Purchase Settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <app name="purchase" position="inside">
                <block title="Purchase Backdate Settings" name="purchase_backdate">
                    <div class="row mt16 o_settings_container">

                        <!--                         Backdate Toggle -->
                        <div class="col-12 o_setting_box" style="width:100%">
                            <div class="o_setting_left_pane">
                                <field name="purchase_order_backdate"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="purchase_order_backdate"/>
                            </div>
                        </div>
                        <!-- Conditional Settings Row -->
                        <div class="row" invisible="purchase_order_backdate == False">

                            <!-- Left Column -->
                            <div class="col-6">
                                <!-- Bill Backdate -->
                                <div class="o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name='bill_backdate' class="oe_inline ms-2"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for='bill_backdate' class='mr-3'/>
                                    </div>
                                </div>

                                <!-- Receipt Backdate -->
                                <div class="o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name='stock_move_backdate' class="oe_inline ms-2"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for='stock_move_backdate' class='mr-3'/>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Column -->
                            <div class="col-6">
                                <!-- Notes for PO -->
                                <div class="o_setting_box">
                                    <div class="o_setting_left_pane">
                                        <field name='rcs_notes_for_purchase_order' class="oe_inline ms-2"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for='rcs_notes_for_purchase_order' class='mr-3'/>
                                    </div>
                                </div>

                                <!-- Notes Mandatory -->
                                <div class="o_setting_box" invisible="rcs_notes_for_purchase_order == False">
                                    <div class="o_setting_left_pane">
                                        <field name='rcs_notes_mandatory_for_purchase_order' class="oe_inline ms-2"/>
                                    </div>
                                    <div class="o_setting_right_pane">
                                        <label for='rcs_notes_mandatory_for_purchase_order' class='mr-3'/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </block>
            </app>
        </field>
    </record>
</odoo>
