<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="stock_move_line_inherit_view_form" model="ir.ui.view">
        <field name="name">stock.move.line.inherit.view.form</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form"/>
        <field name="arch" type="xml">
            <field name="lot_id" position="after">
                <field name="rcs_notes_for_purchase" invisible="not rcs_notes_for_purchase or not is_rcs_notes_for_purchase"/>
                <field name="is_rcs_notes_for_purchase" invisible="1"/>
            </field>
        </field>
    </record>
</odoo>
